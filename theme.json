					"slug": "base"
				},
				{
					"color": "#111111",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#f1f1f1",
					"name": "Accent 1",
					"slug": "accent-1"
				},
				{
					"color": "#eee5ff",
					"name": "Accent 2",
					"slug": "accent-2"
				},
				{
					"color": "#7f39fa",
					"name": "Accent 3",
					"slug": "accent-3"
				},
				{
					"color": "#686868",
					"name": "Accent 4",
					"slug": "accent-4"
				},
				{
					"color": "#efffe5",
					"name": "Accent 5",
					"slug": "accent-5"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Accent 6",
					"slug": "accent-6"
				},
				{
					"color": "#7f39fa",
					"name": "Menu base",
					"slug": "menu-base"
				},
				{
					"color": "#ffffff",
					"name": "Menu contrast",
					"slug": "menu-contrast"
				},
				{
					"color": "#000000",
					"name": "Base dark",
					"slug": "base-dark"
				},
				{
					"color": "#ffffff",
					"name": "Contrast dark",
					"slug": "contrast-dark"
				},
				{
					"color": "#222222",
					"name": "Accent 1 dark",
					"slug": "accent-1-dark"
				},
				{
					"color": "#311f53",
					"name": "Accent 2 dark",
					"slug": "accent-2-dark"
				},
				{
					"color": "#ab81f6",
					"name": "Accent 3 dark",
					"slug": "accent-3-dark"
				},
				{
					"color": "#9a9a9a",
					"name": "Accent 4 dark",
					"slug": "accent-4-dark"
				},
				{
					"color": "#213118",
					"name": "Accent 5 dark",
					"slug": "accent-5-dark"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Accent 6 dark",
					"slug": "accent-6-dark"
				},
				{
					"color": "#7f39fa",
					"name": "Menu base dark",
					"slug": "menu-base-dark"
				},
				{
					"color": "#ffffff",
					"name": "Menu contrast dark",
					"slug": "menu-contrast-dark"
				}
			]
		},
		"layout": {
			"allowEditing": true,
			"contentSize": "800px",
			"wideSize": "1100px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "clamp(12px, 4vw, 20px)",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "clamp(15px, 4vw, 30px)",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(20px, 5vw, 50px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(30px, 7vw, 70px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(50px, 7vw, 90px)",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "clamp(70px, 10vw, 140px)",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "ui-sans-serif, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", sans-serif",
					"name": "System Sans Serif",
					"slug": "system-sans-serif"
				},
				{
					"fontFamily": "ui-serif, Georgia, serif",
					"name": "System Serif",
					"slug": "system-serif"
				},
				{
					"fontFamily": "ui-monospace, Menlo, Consolas, Monaco, \"Liberation Mono\", \"Lucida Console\", monospace",
					"name": "System Monospace",
					"slug": "system-monospace"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.125rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.375rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.38rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2rem",
						"min": "1.5rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2.15rem"
					},
					"name": "Extra Extra Large",
					"size": "2.15rem",
					"slug": "xx-large"
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/accordion-heading": {
				"color": [],
				"css": "/*Core has weird hover spacing, so we specify this here to make sure it never jumps around*/ &__toggle {padding-top: var(--wp--preset--spacing--30) !important} &__toggle:hover {padding-top: var(--wp--preset--spacing--30) !important}",
				"spacing": {
					"blockGap": "0",
					"padding": {
						"bottom": "var(--wp--preset--spacing--20)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--20)"
					}
				}
			},
			"core/accordion-item": {
				"color": {
					"background": "var(--wp--preset--color--accent-1)"
				},
				"spacing": {
					"blockGap": "0"
				}
			},
			"core/accordion-panel": {
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)"
					}
				}
			},
			"core/categories": {
				"color": {
					"text": "var(--wp--preset--color--accent-4)"
				},
				"css": "list-style: none;padding:0;",
				"elements": {
					"link": {
						"typography": {
							"fontWeight": "500",
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontWeight": "300"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--accent-1)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-monospace)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "500"
				}
			},
			"core/comment-author-name": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-3)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "900"
				}
			},
			"core/comment-date": {
				"color": {
					"text": "var(--wp--preset--color--accent-4)"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "color-mix(in srgb, var(--wp--preset--color--accent-3) 85%, transparent)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						},
						"css": "text-decoration: none"
					}
				}
			},
			"core/comment-edit-link": {
				"border": {
					"radius": "100px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent-1)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-3)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--accent-4)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--30)"
					},
					"padding": {
						"bottom": ".25rem",
						"left": ".75rem",
						"right": ".75rem",
						"top": ".25rem"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-reply-link": {
				"border": {
					"radius": "100px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent-1)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-3)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--accent-4)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"padding": {
						"bottom": ".25rem",
						"left": ".75rem",
						"right": ".75rem",
						"top": ".25rem"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/image": {
				"border": {
					"radius": "var(--jer--preset--round-corners--default)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"core/post-author-name": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600"
				}
			},
			"core/post-comments-form": {
				"color": {
					"background": "var(--wp--preset--color--accent-1)"
				},
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--60)"
					},
					"padding": {
						"bottom": "var(--wp--preset--spacing--20)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--20)"
					}
				}
			},
			"core/post-content": {
				"elements": {
					"h1": {
						"spacing": {
							"padding": {
								"top": "var(--wp--preset--spacing--20)"
							}
						}
					},
					"h2": {
						"spacing": {
							"padding": {
								"top": "var(--wp--preset--spacing--20)"
							}
						}
					},
					"h3": {
						"spacing": {
							"padding": {
								"top": "var(--wp--preset--spacing--20)"
							}
						}
					},
					"h4": {
						"spacing": {
							"padding": {
								"top": "var(--wp--preset--spacing--20)"
							}
						}
					},
					"h5": {
						"spacing": {
							"padding": {
								"top": "var(--wp--preset--spacing--20)"
							}
						}
					},
					"h6": {
						"spacing": {
							"padding": {
								"top": "var(--wp--preset--spacing--20)"
							}
						}
					}
				},
				"typography": {
					"lineHeight": "1.7"
				}
			},
			"core/post-date": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "var(--jer--preset--round-corners--default)"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"textDecoration": "none"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-3)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--20)"
					}
				},
				"typography": {
					"fontSize": "clamp(1.75rem, 3vw, 3rem)",
					"fontWeight": "900"
				}
			},
			"core/query-pagination": {
				"color": {
					"text": "var(--wp--preset--color--accent-4)"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--accent-1)",
					"style": "solid",
					"width": "0 0 0 6px"
				},
				"elements": {
					"cite": {
						"color": {
							"text": "var(--wp--preset--color--accent-4)"
						},
						"css": "& sub { font-size: 0.65em }",
						"typography": {
							"fontSize": "var(--wp--preset--font-size--medium)"
						}
					}
				},
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/site-title": {
				"css": "text-shadow: clamp(1px, .15vw, 2px) clamp(1px, .15vw, 2px) 0px color-mix(in srgb, var(--wp--preset--color--accent-3) 85%, transparent);",
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"spacing": {
							"padding": {
								"left": ".5rem",
								"right": ".5rem"
							}
						},
						"typography": {
							"fontWeight": "900",
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontFamily": "inherit",
					"fontSize": "clamp(2rem, 5vw, 3.75rem)",
					"fontStyle": "inherit",
					"fontWeight": "900",
					"textTransform": "inherit"
				}
			},
			"core/term-description": {
				"color": {
					"text": "var(--wp--preset--color--accent-4)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			}
		},
		"css": ".round-image-container img {border-radius: 50%;} :root{ --jer--preset--round-corners--default: 12px;} :root .wp-block-post .wp-block-post-date,:root .wp-block-post .wp-block-post-terms {margin-block-start: clamp(.15rem, 1vw, .25rem);}.jer-rounded-group {border-radius:  var(--jer--preset--round-corners--default);} .home .jer-intro-footer-container, .single .jer-intro-footer-container {display:none;} .paged .jer-intro-footer-container {display: block} .paged .jer-intro-header-container{display:none;} code {font-family: var(--wp--preset--font-family--system-monospace);background: var(--wp--preset--color--accent-1);color: var(--wp--preset--color--contrast);padding: .1em .2em;font-size: .9em;}",
		"elements": {
			"button": {
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--accent-4)",
						"offset": "2px"
					}
				},
				":hover": {
					"border": {
						"color": "transparent"
					},
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--accent-3) 85%, transparent)"
					}
				},
				"color": {
					"background": "var(--wp--preset--color--accent-3)",
					"text": "var(--wp--preset--color--base)"
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--accent-4)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.5"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "clamp(1.5rem, 3vw, 2rem)",
					"fontWeight": "900"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "clamp(1.5rem, 3vw, 2rem)",
					"fontWeight": "900"
				}
			},
			"h3": {
				"typography": {
					"fontWeight": "900"
				}
			},
			"h4": {
				"typography": {
					"fontWeight": "900"
				}
			},
			"h5": {
				"typography": {
					"fontWeight": "900"
				}
			},
			"h6": {
				"typography": {
					"fontWeight": "900"
				}
			},
			"link": {
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--accent-3)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans-serif)",
			"fontSize": "var(--wp--preset--font-size--large)",
			"fontWeight": "400",
			"letterSpacing": "",
			"lineHeight": "1.5"
		}
	}
}